Bootstrap: docker
From: python:3.14.3

%labels
    Author Dylan Woods
    Application PMET
    Version 0.3.1

%files
    ../src /opt/pmet/src
    ../README.md /opt/pmet
    ../LICENSE /opt/pmet
    ../requirements.txt /opt/pmet
    ../pmet.py /opt/pmet

%environment
    export PATH=/opt/pmet:$PATH
    export PYTHONUNBUFFERED=1

%post
    pip install --no-cache-dir -r /opt/pmet/requirements.txt

%runscript
    cd /opt/pmet
    exec python pmet.py "$@"
